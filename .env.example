# Puerto del servidor HTTP (por defecto: 8080)
PORT=8080

# URL de conexión a PostgreSQL de Supabase
# Usa el puerto 6543 (PgBouncer/Transaction mode) para compatibilidad con el pool de conexiones
DATABASE_URL=postgres://postgres:password@db.xxxx.supabase.co:6543/postgres?sslmode=require

# Clave secreta JWT de Supabase (almacenada en config pero la validación usa JWKS/ES256)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# URL base del proyecto Supabase (ej: https://xxxx.supabase.co)
SUPABASE_URL=https://xxxx.supabase.co

# Clave anónima pública de Supabase (usada como apikey en Auth API)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key de Supabase — necesaria para operaciones de Storage (upload, signed URLs, delete)
# NUNCA expongas esta clave al cliente. Solo se usa en el servidor.
# La encuentras en: Dashboard de Supabase > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Nombre del bucket de Supabase Storage donde se almacenan los e-books (por defecto: ebooks)
# Créalo en: Dashboard de Supabase > Storage > New bucket
# Recomendado: bucket privado (no público) para usar signed URLs en descargas
SUPABASE_BUCKET=ebooks
